{
  "name": "budgeting-app",
  "version": "1.0.0",
  "description": "Personal budgeting and savings tracker",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "build:win": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.budgettracker",
    "productName": "Budget Tracker",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.3.4"
  }
}
