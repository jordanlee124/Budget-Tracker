{
  "name": "budgeting-app",
  "version": "1.0.1",
  "description": "Personal budgeting and savings tracker",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "build:win": "npm run build && electron-builder --win",
    "build:win:portable": "npm run build && electron-builder --win portable",
    "release:win": "npm run build && electron-builder --win --publish always",
    "release:mac": "npm run build && electron-builder --mac --publish always"
  },
  "build": {
    "appId": "com.budgettracker",
    "productName": "Budget Tracker",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.finance"
    },
    "publish": {
      "provider": "github",
      "owner": "jordanlee124",
      "repo": "Budget-Tracker"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "png-to-ico": "^3.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "vite": "^5.3.4"
  },
  "dependencies": {
    "pdf-parse": "^1.1.1"
  }
}
